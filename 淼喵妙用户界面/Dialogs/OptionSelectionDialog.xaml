<Window x:Class="淼喵妙用户界面.Dialogs.OptionSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择选项" Height="320" Width="380"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Topmost="True"
        Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="{Binding Prompt}" Margin="15" 
                   Foreground="#FF323232" FontSize="14" FontFamily="Microsoft YaHei" TextWrapping="Wrap"/>
        
        <ListBox x:Name="OptionListBox" Grid.Row="1" Margin="15"
                 SelectionMode="Single"
                 Background="#FFFAFAFA" Foreground="#FF323232"
                 BorderBrush="#FFE0E0E0" BorderThickness="1"
                 SelectedIndex="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="#FFE8E8E8" Margin="2" Padding="8,5,8,5">
                        <TextBlock Text="{Binding}" Foreground="#FF323232" FontFamily="Microsoft YaHei"/>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10,15,10,10">
            <Button Content="确定" Width="80" Height="32" Click="OKButton_Click"
                    Background="#FF409EFF" Foreground="White" BorderBrush="Transparent"
                    FontFamily="Microsoft YaHei" FontSize="14">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF50A8FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF3088EF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>