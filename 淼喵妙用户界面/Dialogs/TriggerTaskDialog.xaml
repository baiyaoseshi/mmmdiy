<Window x:Class="淼喵妙用户界面.Dialogs.TriggerTaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加触发任务" Height="300" Width="400"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Background="#FF2C2C2C">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" VerticalAlignment="Center">
            <TextBlock Text="任务名称:" Width="80" Foreground="White"/>
            <TextBox Text="{Binding TaskName}" Width="250" Background="#FF3C3C3C" Foreground="White" BorderBrush="#FF5C5C5C"/>
        </StackPanel>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10" VerticalAlignment="Center">
            <TextBlock Text="脚本文件:" Width="80" Foreground="White"/>
            <TextBox Text="{Binding ScriptPath}" Width="200" Background="#FF3C3C3C" Foreground="White" BorderBrush="#FF5C5C5C" IsReadOnly="True"/>
            <Button Content="浏览" Width="50" Margin="5,0,0,0" Click="BrowseButton_Click" Background="#FF007ACC" Foreground="White"/>
        </StackPanel>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10" VerticalAlignment="Center">
            <TextBlock Text="触发类型:" Width="80" Foreground="White"/>
            <ComboBox SelectedValue="{Binding TriggerType}" SelectedValuePath="Content" Width="250" Background="White" Foreground="Black" TextElement.Foreground="Black">
                <ComboBox.Resources>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="White"/>
                    </Style>
                </ComboBox.Resources>
                <ComboBoxItem>指令</ComboBoxItem>
            </ComboBox>
        </StackPanel>
        
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="10" VerticalAlignment="Center">
            <TextBlock Text="延迟执行:" Width="80" Foreground="White"/>
            <TextBox Text="{Binding DelaySeconds}" Width="50" Background="#FF3C3C3C" Foreground="White" BorderBrush="#FF5C5C5C"/>
            <TextBlock Text="秒" Margin="5,0,0,0" Foreground="White"/>
            <CheckBox IsChecked="{Binding IsEnabled}" Content="启用" Margin="20,0,0,0" Foreground="White"/>
        </StackPanel>
        
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="确定" Width="75" Height="25" Margin="5" Click="OKButton_Click" Background="#FF007ACC" Foreground="White"/>
            <Button Content="取消" Width="75" Height="25" Margin="5" Click="CancelButton_Click" Background="#FF3C3C3C" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>