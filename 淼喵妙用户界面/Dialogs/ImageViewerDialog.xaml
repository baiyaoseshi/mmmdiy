<Window x:Class="淼喵妙用户界面.Dialogs.ImageViewerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="图片查看" Height="700" Width="960"
        MinHeight="360" MinWidth="480"
        WindowStyle="ToolWindow" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner" Topmost="True"
        Background="White">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFF5F5F5" BorderBrush="#FFE0E0E0"
                BorderThickness="1" Margin="0,0,0,10">
            <Image x:Name="ImageDisplay" 
                   Stretch="Uniform" 
                   StretchDirection="DownOnly"
                   Margin="8"/>
        </Border>

        <StackPanel Grid.Row="1">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="PrevButton" Grid.Column="0" 
                        Content="◀ 上一张" Width="90" Height="32"
                        Click="PrevButton_Click"
                        FontFamily="Microsoft YaHei" FontSize="13"
                        Background="#FF409EFF" Foreground="White" 
                        BorderBrush="Transparent" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#FFC0C0C0"/>
                                    <Setter Property="Foreground" Value="#FF909090"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF50A8FF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center" 
                            Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="IndexLabel" Text="1 / 1"
                               FontFamily="Microsoft YaHei" FontSize="14"
                               Foreground="#FF323232" Margin="0,0,12,0"/>
                    <TextBlock x:Name="SizeLabel" Text=""
                               FontFamily="Microsoft YaHei" FontSize="13"
                               Foreground="#FF909090"/>
                </StackPanel>

                <Button x:Name="NextButton" Grid.Column="2" 
                        Content="下一张 ▶" Width="90" Height="32"
                        Click="NextButton_Click"
                        FontFamily="Microsoft YaHei" FontSize="13"
                        Background="#FF409EFF" Foreground="White" 
                        BorderBrush="Transparent" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#FFC0C0C0"/>
                                    <Setter Property="Foreground" Value="#FF909090"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF50A8FF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
