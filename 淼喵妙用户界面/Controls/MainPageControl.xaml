<UserControl x:Class="淼喵妙用户界面.Controls.MainPageControl"
             x:Name="MainPageControlRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:淼喵妙用户界面.ViewModels"
             xmlns:converters="clr-namespace:淼喵妙用户界面.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#FFE5E5E5">
    <UserControl.Resources>
        <converters:StatusColorConverter x:Key="StatusColorConverter"/>
        <converters:EnabledConverter x:Key="EnabledConverter"/>
        <converters:EnabledColorConverter x:Key="EnabledColorConverter"/>
        <converters:CountdownConverter x:Key="CountdownConverter"/>
        <converters:ModeButtonColorConverter x:Key="ModeButtonColorConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:StringEqualityConverter x:Key="StringEqualityConverter"/>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="5" Background="#FFC0C0C0">
            <Button Content="任务管理" Width="100" Height="30" Margin="5"
                    Background="{Binding IsTaskManagementMode, Converter={StaticResource ModeButtonColorConverter}}" 
                    Foreground="White"
                    Click="SwitchToTaskManagementButton_Click"/>
            <Button Content="运行状态" Width="100" Height="30" Margin="5"
                    Background="{Binding IsTaskManagementMode, Converter={StaticResource ModeButtonColorConverter}, ConverterParameter=reverse}" 
                    Foreground="White"
                    Click="SwitchToRunningStatusButton_Click"/>
            <Button Content="智能化" Width="80" Height="30" Margin="5"
                    Background="#FF9C27B0" Foreground="White"
                    Click="AIButton_Click"/>
        </StackPanel>
        
        <Grid Grid.Row="1" Background="#FFE5E5E5">
            <Grid.Style>
                <Style>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsTaskManagementMode}" Value="True">
                            <Setter Property="Grid.Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsTaskManagementMode}" Value="False">
                            <Setter Property="Grid.Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Background="#FFD0D0D0" Margin="5" CornerRadius="5">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="10,5">
                            <TextBlock Text="分类列表" FontSize="14" FontWeight="Bold" Foreground="Black"/>
                        </StackPanel>
                        <TextBlock Text="{Binding FilteredCategoryName}" 
                                   Foreground="#FF1976D2" FontSize="12" 
                                   Margin="10,0,10,5"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400" Margin="5">
                            <ItemsControl ItemsSource="{Binding TaskCategories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:TaskCategoryViewModel}">
                                        <StackPanel>
                                            <Border Padding="4,3" Cursor="Hand"
                                                    PreviewMouseLeftButtonDown="CategoryItem_PreviewMouseLeftButtonDown"
                                                    PreviewMouseRightButtonDown="CategoryItem_PreviewMouseRightButtonDown">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Value="True">
                                                                <DataTrigger.Binding>
                                                                    <MultiBinding Converter="{StaticResource StringEqualityConverter}">
                                                                        <Binding Path="CategoryName"/>
                                                                        <Binding Path="DataContext.FilteredCategoryName" ElementName="MainPageControlRoot"/>
                                                                    </MultiBinding>
                                                                </DataTrigger.Binding>
                                                                <Setter Property="Background" Value="#FFBBDEFB"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Width="15" VerticalAlignment="Center" FontSize="10" Foreground="#666">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="▶"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                        <Setter Property="Text" Value="▼"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <Border Width="10" Height="10" CornerRadius="5"
                                                            Background="{Binding CategoryColor}" Margin="5,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding CategoryName}" Foreground="Black" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ItemsControl ItemsSource="{Binding SubCategories}"
                                                          Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                          Margin="30,0,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type viewModels:TaskCategoryViewModel}">
                                                        <Border Padding="4,3" Cursor="Hand"
                                                                PreviewMouseLeftButtonDown="CategoryItem_PreviewMouseLeftButtonDown"
                                                                PreviewMouseRightButtonDown="CategoryItem_PreviewMouseRightButtonDown">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Value="True">
                                                                            <DataTrigger.Binding>
                                                                                <MultiBinding Converter="{StaticResource StringEqualityConverter}">
                                                                                    <Binding Path="CategoryName"/>
                                                                                    <Binding Path="DataContext.FilteredCategoryName" ElementName="MainPageControlRoot"/>
                                                                                </MultiBinding>
                                                                            </DataTrigger.Binding>
                                                                            <Setter Property="Background" Value="#FFBBDEFB"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Width="10" Height="10" CornerRadius="5"
                                                                        Background="{Binding CategoryColor}" Margin="5,0" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding CategoryName}" Foreground="Black" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <Button Content="添加分类" Margin="5" Height="30"
                                Background="#FF808080" Foreground="White"
                                Click="AddCategoryButton_Click"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="1" Background="#FFE5E5E5" Margin="5" CornerRadius="5">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="10,5">
                            <TextBlock Text="任务列表" FontSize="14" FontWeight="Bold" Foreground="Black"/>
                            <TextBlock Text=" (" Foreground="#FF666666"/>
                            <TextBlock Text="{Binding FilteredSavedTasks.Count}" Foreground="#FF606060"/>
                            <TextBlock Text=")" Foreground="#FF666666"/>
                        </StackPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="400">
                            <ItemsControl ItemsSource="{Binding FilteredSavedTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:SavedTaskViewModel}">
                                        <Border Background="#FFC0C0C0" Margin="5" Padding="5" CornerRadius="3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <Border Width="20" Height="20" CornerRadius="10" 
                                                            Background="{Binding CategoryColor}" 
                                                            VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding TaskName}" Foreground="Black" FontSize="14" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding ScriptPath}" Foreground="#FF666666" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Content="打开" Width="50" Height="25" Margin="2"
                                                            Background="#FF2196F3" Foreground="White"
                                                            Click="SavedTaskOpenButton_Click"/>
                                                    <Button Content="添加到队列" Width="80" Height="25" Margin="2"
                                                            Background="#FF4CAF50" Foreground="White"
                                                            Click="SavedTaskAddToQueueButton_Click"/>
                                                    <Button Content="移动" Width="50" Height="25" Margin="2"
                                                            Background="#FFFF9800" Foreground="White"
                                                            Click="SavedTaskMoveToCategoryButton_Click"/>
                                                    <Button Content="删除" Width="50" Height="25" Margin="2"
                                                            Background="#FFF44336" Foreground="White"
                                                            Click="SavedTaskDeleteButton_Click"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
        
        <Grid Grid.Row="1" Background="#FFE5E5E5">
            <Grid.Style>
                <Style>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsTaskManagementMode}" Value="False">
                            <Setter Property="Grid.Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsTaskManagementMode}" Value="True">
                            <Setter Property="Grid.Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Background="#FFF0F0F0" Margin="5" CornerRadius="5">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="10,5">
                            <TextBlock Text="任务队列" FontSize="14" FontWeight="Bold" Foreground="Black"/>
                            <TextBlock Text=" (" Foreground="#FF666666"/>
                            <TextBlock Text="{Binding TaskQueue.Count}" Foreground="#FF606060"/>
                            <TextBlock Text=")" Foreground="#FF666666"/>
                        </StackPanel>
                        <Button Content="添加任务" Width="80" Height="25" Margin="5" HorizontalAlignment="Left"
                                Background="#FF007ACC" Foreground="White"
                                Click="AddTaskToQueueButton_Click"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="420">
                            <ItemsControl ItemsSource="{Binding TaskQueue}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:TaskItemViewModel}">
                                        <Border Background="#FFC0C0C0" Margin="5" Padding="5" CornerRadius="3">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" Foreground="Black" FontSize="14" FontWeight="Bold"/>
                                                    <TextBlock Text=" (" Foreground="#FF666666" Margin="2,0"/>
                                                    <TextBlock Text="{Binding Type}" Foreground="#FF666666" FontSize="12"/>
                                                    <TextBlock Text=")" Foreground="#FF666666" Margin="0,0,5,0"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="状态: " Foreground="#FF666666" FontSize="12"/>
                                                    <TextBlock Text="{Binding Status}" 
                                                               Foreground="{Binding Status, Converter={StaticResource StatusColorConverter}}"
                                                               FontSize="12"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="删除" Width="50" Height="25" Margin="2"
                                                            Background="#FFF44336" Foreground="White"
                                                            Click="TaskItemDeleteButton_Click"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="1" Background="#FFE8F5E9" Margin="5" CornerRadius="5">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="10,5">
                            <TextBlock Text="定时任务" FontSize="14" FontWeight="Bold" Foreground="Black"/>
                            <TextBlock Text=" (" Foreground="#FF666666"/>
                            <TextBlock Text="{Binding ScheduledTasks.Count}" Foreground="#FF606060"/>
                            <TextBlock Text=")" Foreground="#FF666666"/>
                        </StackPanel>
                        <Button Content="添加定时任务" Width="100" Height="25" Margin="5" HorizontalAlignment="Left"
                                Background="#FF4CAF50" Foreground="White"
                                Click="AddScheduledTaskButton_Click"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="420">
                            <ItemsControl ItemsSource="{Binding ScheduledTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:ScheduledTaskViewModel}">
                                        <Border Background="#FFC8E6C9" Margin="5" Padding="5" CornerRadius="3">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding TaskName}" Foreground="Black" FontSize="14" FontWeight="Bold"/>
                                                    <Border Width="10" Height="10" CornerRadius="5" 
                                                            Background="{Binding CategoryColor, FallbackValue=#FF808080}" 
                                                            Margin="5" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding 调度描述}" 
                                                               Foreground="#FF4CAF50" FontSize="12" FontWeight="Bold"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="状态: " Foreground="#FF666666" FontSize="12"/>
                                                    <TextBlock Text="{Binding IsEnabled, Converter={StaticResource EnabledConverter}}" 
                                                               Foreground="{Binding IsEnabled, Converter={StaticResource EnabledColorConverter}}"
                                                               FontSize="12"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="编辑" Width="50" Height="25" Margin="2"
                                                            Background="#FF007ACC" Foreground="White"
                                                            Click="ScheduledTaskEditButton_Click"/>
                                                    <Button Content="删除" Width="50" Height="25" Margin="2"
                                                            Background="#FFF44336" Foreground="White"
                                                            Click="ScheduledTaskDeleteButton_Click"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="2" Background="#FFF3E0" Margin="5" CornerRadius="5">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="10,5">
                            <TextBlock Text="触发任务" FontSize="14" FontWeight="Bold" Foreground="Black"/>
                            <TextBlock Text=" (" Foreground="#FF666666"/>
                            <TextBlock Text="{Binding TriggerTasks.Count}" Foreground="#FF606060"/>
                            <TextBlock Text=")" Foreground="#FF666666"/>
                        </StackPanel>
                        <Button Content="添加触发任务" Width="100" Height="25" Margin="5" HorizontalAlignment="Left"
                                Background="#FFFF9800" Foreground="Black"
                                Click="AddTriggerTaskButton_Click"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="420">
                            <ItemsControl ItemsSource="{Binding TriggerTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:TriggerTaskViewModel}">
                                        <Border Background="#FFEFE0" Margin="5" Padding="5" CornerRadius="3">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding TaskName}" Foreground="Black" FontSize="14" FontWeight="Bold"/>
                                                    <Border Width="10" Height="10" CornerRadius="5" 
                                                            Background="{Binding CategoryColor, FallbackValue=#FF808080}" 
                                                            Margin="5" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="触发类型: " Foreground="#FF666666" FontSize="12"/>
                                                    <TextBlock Text="{Binding TriggerType}" 
                                                               Foreground="#FF4CAF50" FontSize="12" FontWeight="Bold"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="延迟: " Foreground="#FF666666" FontSize="12"/>
                                                    <TextBlock Text="{Binding DelaySeconds}" Foreground="#FF666666" FontSize="12"/>
                                                    <TextBlock Text="秒" Foreground="#FF666666" FontSize="12"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="状态: " Foreground="#FF666666" FontSize="12"/>
                                                    <TextBlock Text="{Binding IsEnabled, Converter={StaticResource EnabledConverter}}" 
                                                               Foreground="{Binding IsEnabled, Converter={StaticResource EnabledColorConverter}}"
                                                               FontSize="12"/>
                                                </StackPanel>
                                                <Button Content="删除" Width="50" Height="25" Margin="2"
                                                        Background="#FFF44336" Foreground="White"
                                                        Click="TriggerTaskDeleteButton_Click"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
        
        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="任务队列" Foreground="#FF666666"/>
                <TextBlock Text=" (" Foreground="#FF666666"/>
                <TextBlock Text="{Binding TaskQueue.Count}" Foreground="#FF606060"/>
                <TextBlock Text=")" Foreground="#FF666666"/>
                <TextBlock Text=" | 定时任务: " Foreground="#FF666666"/>
                <TextBlock Text="{Binding ScheduledTasks.Count}" Foreground="#FF606060"/>
                <TextBlock Text=" | 触发任务: " Foreground="#FF666666"/>
                <TextBlock Text="{Binding TriggerTasks.Count}" Foreground="#FF606060"/>
                <TextBlock Text=" | 保存任务: " Foreground="#FF666666"/>
                <TextBlock Text="{Binding SavedTasks.Count}" Foreground="#FF606060"/>
            </StackPanel>
            <Expander Header="远程指令设置" Margin="5,2" IsExpanded="False" Foreground="#FF444444">
                <StackPanel Margin="10,5">
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="启用:" Foreground="Black" Width="60" VerticalAlignment="Center"/>
                        <CheckBox IsChecked="{Binding 远程指令配置.是否启用}" 
                                  Checked="远程指令开关_Changed" Unchecked="远程指令开关_Changed"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="端口:" Foreground="Black" Width="60" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding 远程指令配置.端口号}" Width="80" Height="24" 
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="令牌:" Foreground="Black" Width="60" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding 远程指令配置.认证令牌}" Width="200" Height="24"
                                 VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="状态:" Foreground="Black" Width="60" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding 远程指令状态文本}" Foreground="#FF4CAF50" 
                                   VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBlock Text="Tailscale IP 可在系统托盘 Tailscale 图标中查看" 
                               Foreground="#FF999999" FontSize="11" Margin="0,3,0,0"/>
                    <Button Content="应用设置" Width="80" Height="25" Margin="0,5,0,0"
                            Background="#FF4CAF50" Foreground="White"
                            Click="应用远程指令设置_Click"/>
                </StackPanel>
            </Expander>
        </StackPanel>
    </Grid>
</UserControl>