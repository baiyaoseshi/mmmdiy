<UserControl x:Class="淼喵妙用户界面.Controls.GlobalAISettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="350"
             Background="#FFF5F5F5">
    <Border Background="#FFF5F5F5" BorderBrush="#FFC0C0C0" BorderThickness="1,0,0,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="全局设置" FontSize="16" FontWeight="Bold" Foreground="#FF333333"
                               VerticalAlignment="Center"/>
                    <Button Content="✕" Width="30" Height="30" HorizontalAlignment="Right"
                            Background="Transparent" Foreground="#FF666666" Click="CloseButton_Click"/>
                </Grid>

                <TextBlock Text="AI 配置列表" FontSize="14" FontWeight="Bold" Foreground="#FF333333" Margin="0,5,0,5"/>
                <TextBlock Text="管理多个 AI 提供者配置，在对话中可选择使用" FontSize="11" Foreground="#FF888888" Margin="0,0,0,5"/>
                <ListBox x:Name="ConfigListBox" MaxHeight="200" SelectionChanged="ConfigListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding 名称}" FontWeight="Bold"/>
                                <TextBlock Text=" — "/>
                                <TextBlock Text="{Binding 配置.提供者类型}" Foreground="#FF888888"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                    <Button Content="+ 添加配置" Height="28" Background="#FF4CAF50" Foreground="White"
                            Click="AddConfigButton_Click" Margin="0,0,5,0"/>
                    <Button Content="删除" Height="28" Background="#FFE53935" Foreground="White"
                            Click="DeleteConfigButton_Click"/>
                </StackPanel>

                <Grid>
                    <TextBlock Text="配置编辑" FontSize="14" FontWeight="Bold" Foreground="#FF333333"
                               VerticalAlignment="Center"/>
                    <Button Content="保存配置" Height="30" HorizontalAlignment="Right"
                            Background="#FF2196F3" Foreground="White" FontSize="12" Click="SaveCurrentConfig_Click"
                            Padding="12,0"/>
                </Grid>

                <TextBlock Text="配置名称" FontSize="12" FontWeight="Bold" Foreground="#FF555555" Margin="0,2,0,2"/>
                <TextBox x:Name="SelectedConfigNameTextBox"/>

                <TextBlock Text="AI 提供者" FontSize="12" FontWeight="Bold" Foreground="#FF555555" Margin="0,8,0,2"/>
                <ComboBox x:Name="SelectedProviderComboBox" SelectedIndex="0" SelectionChanged="SelectedProviderComboBox_SelectionChanged">
                    <ComboBoxItem Content="Ollama 本地"/>
                    <ComboBoxItem Content="OpenAI 兼容 API"/>
                    <ComboBoxItem Content="DashScope (阿里云)"/>
                </ComboBox>

                <StackPanel x:Name="SelectedOllamaPanel" Visibility="Visible">
                    <TextBlock Text="Ollama 主机地址" FontSize="12" FontWeight="Bold" Foreground="#FF555555" Margin="0,8,0,2"/>
                    <TextBox x:Name="SelectedOllamaHostTextBox" Text="http://localhost:11434"/>

                    <TextBlock Text="Ollama 模型名称" FontSize="12" FontWeight="Bold" Foreground="#FF555555" Margin="0,8,0,2"/>
                    <TextBox x:Name="SelectedOllamaModelTextBox" Text="qwen2:0.5b"/>
                </StackPanel>

                <StackPanel x:Name="SelectedRemoteAPIPanel" Visibility="Collapsed">
                    <TextBlock Text="远程 API 地址" FontSize="12" FontWeight="Bold" Foreground="#FF555555" Margin="0,8,0,2"/>
                    <TextBox x:Name="SelectedRemoteAPIUrlTextBox"/>

                    <TextBlock Text="API 密钥" FontSize="12" FontWeight="Bold" Foreground="#FF555555" Margin="0,8,0,2"/>
                    <PasswordBox x:Name="SelectedAPIKeyPasswordBox"/>

                    <TextBlock Text="模型名称" FontSize="12" FontWeight="Bold" Foreground="#FF555555" Margin="0,8,0,2"/>
                    <TextBox x:Name="SelectedRemoteModelTextBox" Text="deepseek-chat"/>
                </StackPanel>

                <TextBlock Text="Google 搜索" FontSize="12" FontWeight="Bold" Foreground="#FF555555" Margin="0,8,0,2"/>
                <TextBlock Text="在 Google Cloud Console 启用 Custom Search API 并创建 API Key，再在 Programmable Search Engine 获取搜索引擎 ID (CX)。免费配额：每天100次"
                           FontSize="10" Foreground="#FFAAAAAA" Margin="0,2,0,5" TextWrapping="Wrap"/>
                <PasswordBox x:Name="SelectedGoogleAPIKeyPasswordBox"/>

                <TextBlock Text="搜索引擎 ID (CX)" FontSize="12" FontWeight="Bold" Foreground="#FF555555" Margin="0,8,0,2"/>
                <TextBox x:Name="SelectedGoogleCXTextBox"/>

                <TextBlock Text="生成参数" FontSize="14" FontWeight="Bold" Foreground="#FF333333" Margin="0,14,0,5"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="最大输出 Token" FontSize="12" FontWeight="Bold" Foreground="#FF555555"/>
                        <TextBox x:Name="SelectedMaxTokensTextBox" Text="8192"/>
                        <TextBlock Text="DeepSeek 最大 384K，设 0 使用默认" FontSize="10" Foreground="#FFAAAAAA" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="温度（Temperature）" FontSize="12" FontWeight="Bold" Foreground="#FF555555"/>
                        <TextBox x:Name="SelectedTemperatureTextBox" Text=""/>
                        <TextBlock Text="0~2，留空使用默认。思考模式不生效"
                                   FontSize="10" Foreground="#FFAAAAAA" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="全局自定义规则" FontSize="14" FontWeight="Bold" Foreground="#FF333333" Margin="0,5,0,5"/>
                <TextBlock Text="对所有对话生效的行为规则" FontSize="11" Foreground="#FF888888" Margin="0,0,0,5"/>
                <TextBox x:Name="CustomRulesTextBox" TextWrapping="Wrap" AcceptsReturn="True"
                         MinHeight="60" MaxHeight="150" VerticalScrollBarVisibility="Auto"
                         Text="始终用中文回复"/>

                <TextBlock Text="AI 自主学习" FontSize="14" FontWeight="Bold" Foreground="#FF333333" Margin="0,14,0,5"/>
                <CheckBox x:Name="EnableSelfLearningCheckBox" Content="启用印象学习与训练（自动评估工具调用、管理印象、收集训练数据）" 
                          FontSize="12" Foreground="#FF555555" Margin="0,2"/>
                <CheckBox x:Name="EnableStatisticsCheckBox" Content="启用增量记录（记录每次工具调用原始数据，供微调分析）"
                          FontSize="12" Foreground="#FF555555" Margin="0,2"/>
                <CheckBox x:Name="FilterPrivateMessagesCheckBox" Content="过滤私有消息（隐藏 AI 内部提示词、工具执行结果）" 
                          FontSize="12" Foreground="#FF555555" Margin="0,2,0,10"/>

                <TextBlock Text="全局快捷指令" FontSize="14" FontWeight="Bold" Foreground="#FF333333" Margin="0,12,0,5"/>
                <TextBlock Text="在所有对话中均可通过 /触发短语 使用" FontSize="11" Foreground="#FF888888" Margin="0,0,0,5"/>
                <ItemsControl x:Name="QuickCommandsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" Margin="0,2" Padding="5" CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock FontWeight="Bold" Foreground="#FF333333">
                                            <Run Text="/"/><Run Text="{Binding 触发短语}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding 名称}" Foreground="#FF888888" FontSize="11"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="✕" Width="24" Height="24"
                                            Background="Transparent" Foreground="#FFCC0000"
                                            Tag="{Binding 触发短语}" Click="DeleteQuickCommand_Click"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="+ 添加快捷指令" Height="28" Margin="0,5"
                        Background="#FF4CAF50" Foreground="White" Click="AddQuickCommand_Click"/>

                <Button Content="清除自主学习缓存" Height="30" Margin="0,10,0,0"
                        Background="#FFE53935" Foreground="White" FontSize="12" Click="ClearLearningCache_Click"/>

                <TextBlock Text="模型训练与微调" FontSize="14" FontWeight="Bold" Foreground="#FF333333" Margin="0,14,0,5"/>

                <TextBlock Text="经验 AI 配置（仅 Ollama 本地）" FontSize="12" FontWeight="Bold" Foreground="#FF555555" Margin="0,2"/>
                <ComboBox x:Name="ExperienceAIConfigComboBox" Margin="0,2,0,10"/>

                <TextBlock Text="训练进度" FontSize="12" FontWeight="Bold" Foreground="#FF555555" Margin="0,4,0,2"/>
                <TextBlock x:Name="TrainingProgressText" Text="" Foreground="#FF666666" FontSize="11" Margin="0,2,0,5"/>

                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <Button Content="开始训练" Height="28" Background="#FF4CAF50" Foreground="White"
                            Click="StartTraining_Click" Margin="0,0,5,0"/>
                    <Button Content="数据清洗" Height="28" Background="#FFFF9800" Foreground="White"
                            Click="CleanData_Click" Margin="0,0,5,0"/>
                    <Button Content="构建评测集" Height="28" Background="#FF2196F3" Foreground="White"
                            Click="BuildEvalSet_Click" Margin="0,0,5,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <Button Content="清空印象" Height="28" Background="#FFE53935" Foreground="White"
                            Click="ClearImpressions_Click" Margin="0,0,5,0"/>
                    <Button Content="查看印象统计" Height="28" Background="#FF9E9E9E" Foreground="White"
                            Click="ViewTrainingStats_Click"/>
                </StackPanel>

                <Button x:Name="SaveButton" Content="保存全局设置" Height="35" Margin="0,10,0,10"
                        Background="#FF2196F3" Foreground="White" FontSize="14" Click="SaveButton_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
