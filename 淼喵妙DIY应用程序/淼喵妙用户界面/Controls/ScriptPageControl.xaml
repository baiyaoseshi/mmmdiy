<UserControl x:Class="淼喵妙用户界面.Controls.ScriptPageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
            <Button Content="绑定窗口" Margin="0,0,5,0" Padding="10,5"
                    Click="BindWindowButton_Click"
                    Background="#FFE0E0E0" Foreground="Black" BorderBrush="LightGray"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                    ToolTip="点击后选择要绑定的窗口"/>
            <Button Content="添加节点" Margin="0,0,5,0" Padding="10,5"
                    Click="AddNodeButton_Click"
                    Background="#FF007ACC" Foreground="White" BorderBrush="Transparent"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                    ToolTip="添加新的脚本节点"/>
            <Button Content="保存" Padding="10,5"
                    Click="SaveScriptButton_Click"
                    Background="#FF4CAF50" Foreground="White" BorderBrush="Transparent"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                    ToolTip="保存脚本到文件"/>
            <Button Content="停止" Padding="10,5"
                    Click="StopScriptButton_Click"
                    Background="#FFF44336" Foreground="White" BorderBrush="Transparent"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                    ToolTip="一键停止当前页面所有关联任务"/>
            <ToggleButton x:Name="BranchScriptToggle" Content="支线" Padding="10,5" Margin="5,0,0,0"
                          IsChecked="{Binding IsBranchScript}"
                          ToolTip="切换为支线脚本（不进入主队列，并行执行）">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Static ToolBar.ToggleButtonStyleKey}}">
                        <Setter Property="Background" Value="#FFE0E0E0"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="BorderBrush" Value="LightGray"/>
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#FFFF9800"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>
        </StackPanel>
        
        <Border Grid.Row="1" Margin="5" Background="#FFF0F0F0" BorderBrush="LightGray" BorderThickness="1">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="窗口标题:" Foreground="Black" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding WindowTitle, FallbackValue='未绑定'}" Foreground="#FF666666" Margin="5,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="进程名称:" Foreground="Black" VerticalAlignment="Center" Margin="0,5,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ProcessName, FallbackValue='未绑定'}" Foreground="#FF666666" Margin="5,5,0,0" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="备注:" Foreground="Black" VerticalAlignment="Center" Margin="0,5,0,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Remark, FallbackValue='无'}" Foreground="#FF888888" Margin="5,5,0,0" VerticalAlignment="Center" FontStyle="Italic"/>
            </Grid>
        </Border>
        
        <ListBox Grid.Row="2" x:Name="NodeListBox" Margin="5"
                 ItemsSource="{Binding Nodes}"
                 Background="White" Foreground="Black"
                 BorderBrush="Gray"
                 SelectedItem="{Binding SelectedNode}"
                 SelectionMode="Extended"
                 SelectionChanged="NodeListBox_SelectionChanged"
                 AllowDrop="True"
                 PreviewMouseMove="NodeListBox_PreviewMouseMove"
                 PreviewMouseLeftButtonDown="NodeListBox_PreviewMouseLeftButtonDown"
                 Drop="NodeListBox_Drop">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="粘贴" Click="PasteMenuItem_Click"
                              IsEnabled="{Binding DataContext.HasClipboard, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="#E0E0E0" Margin="2" Padding="5" CornerRadius="3">
                        <Border.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="删除" Click="DeleteMenuItem_Click"/>
                                <MenuItem Header="重命名" Click="RenameMenuItem_Click"/>
                                <MenuItem Header="编辑" Click="EditMenuItem_Click"/>
                                <Separator/>
                                <MenuItem Header="添加条件" Click="AddConditionMenuItem_Click"/>
                                <Separator/>
                                <MenuItem Header="复制" Click="CopyMenuItem_Click"/>
                                <MenuItem Header="粘贴" Click="PasteMenuItem_Click"
                                          IsEnabled="{Binding DataContext.HasClipboard, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </ContextMenu>
                        </Border.ContextMenu>
                        <DockPanel>
                            <!-- 拖拽抓手 - 左侧可抓取控件，用于拖拽调整节点顺序 -->
                            <TextBlock Text="⋮⋮" FontSize="16" FontWeight="Bold"
                                       Foreground="#999999" VerticalAlignment="Center"
                                       DockPanel.Dock="Left" Margin="0,0,8,0"
                                       Cursor="SizeAll"
                                       ToolTip="拖拽可调整节点顺序"/>
                            <TextBlock Text="{Binding 节点名字}" Foreground="#666666" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                            <Button Content="执行此节点" Width="65" Height="20" Margin="5,0,0,0"
                                    Background="#FFFF9800" Foreground="White" FontSize="10"
                                    Click="ExecuteSingleNodeButton_Click"
                                    DockPanel.Dock="Right"/>
                            <Button Content="▶ 从此运行" Width="65" Height="20" Margin="5,0,0,0"
                                    Background="#FF2196F3" Foreground="White" FontSize="10"
                                    Click="RunFromNodeButton_Click"
                                    DockPanel.Dock="Right"/>
                            <TextBlock Text="{Binding 状态显示文本}" Foreground="#FF007ACC" DockPanel.Dock="Right" Margin="5,0,0,0" FontSize="10" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>