<UserControl x:Class="淼喵妙用户界面.Controls.AIChatPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:淼喵妙用户界面.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="800"
             Background="#FFE5E5E5">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="SettingsColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FFD0D0D0" Margin="3" CornerRadius="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <Button Content="＋ 新建对话" Height="32" Margin="5"
                            Background="#FF4CAF50" Foreground="White"
                            Click="NewConversationButton_Click"/>
                </StackPanel>

                <ListBox x:Name="ConversationListBox" Grid.Row="1" 
                         Background="Transparent" BorderThickness="0"
                         Margin="3"
                         SelectionChanged="ConversationListBox_SelectionChanged"
                         MouseDoubleClick="ConversationListBox_MouseDoubleClick"
                         ContextMenuOpening="ConversationListBox_ContextMenuOpening">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="删除对话" Click="DeleteConversationMenuItem_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="3">
                                <TextBlock Text="{Binding 名称}" FontSize="13" Foreground="#FF333333" 
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding 消息数量}" FontSize="10" Foreground="#FF888888"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <controls:AIChatControl x:Name="ChatControl" Grid.Row="0"/>

            <Grid Grid.Row="1" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="⚙" Width="36" Height="36" FontSize="18"
                            Background="#FF808080" Foreground="White"
                            Click="SettingsButton_Click" ToolTip="对话设置"/>
                    <Button Content="🌐" Width="36" Height="36" FontSize="18"
                            Background="#FF808080" Foreground="White"
                            Click="GlobalSettingsButton_Click" ToolTip="全局设置"/>
                </StackPanel>
            </Grid>
        </Grid>

        <controls:AIConversationSettings x:Name="SettingsPanel" Grid.Column="2"
                                          Visibility="Collapsed"/>
        <controls:GlobalAISettings x:Name="GlobalSettingsPanel" Grid.Column="2"
                                    Visibility="Collapsed"/>
    </Grid>
</UserControl>
