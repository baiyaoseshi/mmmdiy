<UserControl x:Class="淼喵妙用户界面.Controls.AIChatControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:淼喵妙用户界面.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="600">
    <UserControl.Resources>
        <controls:StringNotEmptyConverter x:Key="StringNotEmptyConverter"/>
        <controls:BoolInvertConverter x:Key="BoolInvertConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer x:Name="MessagesScrollViewer" Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="MessagesItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="5">
                            <Border x:Name="MessageBorder" CornerRadius="8" Padding="10,6" MaxWidth="500"
                                    HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding 角色}" Value="用户">
                                                <Setter Property="Background" Value="#FF2196F3"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding 角色}" Value="AI">
                                                <Setter Property="Background" Value="#FFE0E0E0"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding 角色}" Value="系统">
                                                <Setter Property="Background" Value="#FFFFF3E0"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock x:Name="RoleLabel" Text="系统" 
                                               FontSize="10" Foreground="#FF00838F" FontWeight="Bold"
                                               Margin="0,0,0,3" Visibility="Collapsed">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding 角色}" Value="系统">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Expander x:Name="ThinkingExpander" 
                                              Visibility="{Binding 思考内容, Converter={StaticResource StringNotEmptyConverter}}"
                                              IsExpanded="{Binding 思考已折叠, Converter={StaticResource BoolInvertConverter}, Mode=OneWay}"
                                              Margin="0,0,0,4" Padding="2"
                                              Background="#FFF8F4E8" BorderBrush="#FFD4C5A0"
                                              BorderThickness="1">
                                        <Expander.Header>
                                            <TextBlock Text="🧠 思考过程" FontSize="11" 
                                                       Foreground="#FFA08060" FontStyle="Italic"/>
                                        </Expander.Header>
                                        <TextBlock Text="{Binding 思考内容}" TextWrapping="Wrap" 
                                                   FontSize="11" Foreground="#FF999999" 
                                                   FontStyle="Italic" Margin="4,2"
                                                   MaxHeight="200"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Expander>
                                    <TextBlock x:Name="MessageText" Text="{Binding 内容}" 
                                               TextWrapping="Wrap" FontSize="13"/>
                                    <TextBlock Text="{Binding 时间戳, StringFormat='{}{0:HH:mm:ss}'}" 
                                               FontSize="10" Foreground="#FF888888" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>
                            <Button Content="📋" 
                                    VerticalAlignment="Top" Margin="0,2,0,0"
                                    Width="20" Height="20" Padding="0"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" ToolTip="复制消息内容"
                                    Click="CopyMessage_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="#FF999999"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding 角色}" Value="AI">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding 角色}" Value="系统">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#FF2196F3"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Popup x:Name="QuickCommandPopup" PlacementTarget="{Binding ElementName=InputTextBox}"
                   Placement="Top" StaysOpen="False" AllowsTransparency="True">
                <Border Background="White" BorderBrush="#FFC0C0C0" BorderThickness="1" CornerRadius="4"
                        MaxHeight="200" MinWidth="200">
                    <ListBox x:Name="QuickCommandListBox" 
                             KeyDown="QuickCommandListBox_KeyDown"
                             MouseLeftButtonUp="QuickCommandListBox_MouseLeftButtonUp">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="/" Foreground="#FF2196F3" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding 触发短语}" Margin="2,0" Foreground="#FF2196F3"/>
                                    <TextBlock Text=" - " Foreground="#FF999999"/>
                                    <TextBlock Text="{Binding 名称}" Foreground="#FF666666"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Popup>

            <TextBox x:Name="InputTextBox" Grid.Column="0" 
                     TextWrapping="Wrap" AcceptsReturn="True"
                     MinHeight="30" MaxHeight="100"
                     PreviewKeyDown="InputTextBox_PreviewKeyDown"
                     TextChanged="InputTextBox_TextChanged"
                     VerticalScrollBarVisibility="Auto"/>
            <Button x:Name="SendButton" Grid.Column="1" Content="发送" Width="60" Height="30" Margin="5,0,0,0"
                    Background="#FF2196F3" Foreground="White" Click="SendButton_Click"/>
        </Grid>
    </Grid>
</UserControl>
