<UserControl x:Class="淼喵妙用户界面.Controls.AIConversationSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="350"
             Background="#FFF5F5F5">
    <Border Background="#FFF5F5F5" BorderBrush="#FFC0C0C0" BorderThickness="1,0,0,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="对话设置" FontSize="16" FontWeight="Bold" Foreground="#FF333333"
                               VerticalAlignment="Center"/>
                    <Button Content="✕" Width="30" Height="30" HorizontalAlignment="Right"
                            Background="Transparent" Foreground="#FF666666" Click="CloseButton_Click"/>
                </Grid>

                <TextBlock Text="MCP 工具库分类" FontSize="14" FontWeight="Bold" Foreground="#FF333333" Margin="0,12,0,5"/>
                <TextBlock Text="选择脚本分类作为 AI 工具库" FontSize="11" Foreground="#FF888888" Margin="0,0,0,5"/>
                <ItemsControl x:Name="CategoryCheckList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding 分类名}" IsChecked="{Binding 是否选中}" Margin="0,2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="AI 模型选择" FontSize="14" FontWeight="Bold" Foreground="#FF333333" Margin="0,12,0,5"/>
                <TextBlock Text="为当前对话选择使用的 AI 模型" FontSize="11" Foreground="#FF888888" Margin="0,0,0,5"/>

                <TextBlock Text="文本模型" FontSize="11" FontWeight="Bold" Foreground="#FF555555" Margin="0,5,0,2"/>
                <ComboBox x:Name="TextModelComboBox" DisplayMemberPath="显示名" Margin="0,0,0,5"/>

                <TextBlock Text="多模态模型（视觉）" FontSize="11" FontWeight="Bold" Foreground="#FF555555" Margin="0,5,0,2"/>
                <ComboBox x:Name="MultimodalModelComboBox" DisplayMemberPath="显示名" Margin="0,0,0,5"/>

                <TextBlock Text="分类AI规则摘要" FontSize="14" FontWeight="Bold" Foreground="#FF333333" Margin="0,12,0,5"
                           x:Name="RuleSummaryHeader" Visibility="Collapsed"/>
                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#FF666666" Margin="0,0,0,8"
                           x:Name="RuleSummaryText" Visibility="Collapsed"/>

                <TextBlock Text="AI 行为" FontSize="14" FontWeight="Bold" Foreground="#FF333333" Margin="0,12,0,5"/>
                <TextBlock Text="最大输出 Token" FontSize="11" FontWeight="Bold" Foreground="#FF555555" Margin="0,6,0,2"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="MaxTokensSlider" Grid.Column="0" Minimum="256" Maximum="384000"
                            Value="8192" TickFrequency="8192" IsSnapToTickEnabled="True"
                            LargeChange="16384" SmallChange="1024"
                            ValueChanged="MaxTokensSlider_ValueChanged" Margin="0,0,5,0"/>
                    <TextBox x:Name="MaxTokensValueText" Grid.Column="1" Text="8192" Width="45"
                             TextAlignment="Center" FontSize="10" IsReadOnly="True"/>
                </Grid>
                <TextBlock Text="全局默认值从全局设置继承。滑块可覆盖当前对话的输出上限。"
                           FontSize="10" Foreground="#FFAAAAAA" Margin="0,2,0,0"/>

                <TextBlock Text="温度（Temperature）" FontSize="11" FontWeight="Bold" Foreground="#FF555555" Margin="0,6,0,2"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="TemperatureSlider" Grid.Column="0" Minimum="0" Maximum="2"
                            Value="0" TickFrequency="0.1" IsSnapToTickEnabled="True"
                            LargeChange="0.2" SmallChange="0.1"
                            ValueChanged="TemperatureSlider_ValueChanged" Margin="0,0,5,0"/>
                    <TextBox x:Name="TemperatureValueText" Grid.Column="1" Text="0.0" Width="45"
                             TextAlignment="Center" FontSize="10" IsReadOnly="True"/>
                </Grid>
                <TextBlock Text="0=精确保守, 2=创意随机。思考模式下不生效。从全局设置继承默认值。"
                           FontSize="10" Foreground="#FFAAAAAA" Margin="0,2,0,0"/>

                <CheckBox x:Name="WebSearchCheckBox" Content="启用网页搜索（联网获取实时信息）"
                          IsChecked="True" Margin="0,8,0,0" Foreground="#FF333333" FontSize="12"/>

                <TextBlock Text="自定义规则" FontSize="14" FontWeight="Bold" Foreground="#FF333333" Margin="0,12,0,5"/>
                <TextBlock Text="当前对话专属的行为规则" FontSize="11" Foreground="#FF888888" Margin="0,0,0,5"/>
                <TextBox x:Name="CustomRulesTextBox" TextWrapping="Wrap" AcceptsReturn="True"
                         MinHeight="60" MaxHeight="150" VerticalScrollBarVisibility="Auto"/>

                <Button x:Name="SaveButton" Content="保存设置" Height="35" Margin="0,15,0,10"
                        Background="#FF2196F3" Foreground="White" FontSize="14" Click="SaveButton_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
