<Window x:Class="淼喵妙用户界面.Dialogs.NodeEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑节点" Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <GroupBox Grid.Row="0" Header="通用属性" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Row="0" Grid.Column="0" Text="节点名称:" VerticalAlignment="Center" Margin="0,5,5,5"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Node.节点名字}" Margin="0,5" Width="200"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="节点备注:" VerticalAlignment="Center" Margin="0,5,5,5"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Node.节点备注}" Margin="0,5" Width="300"/>
                
                <TextBlock Grid.Row="2" Grid.Column="0" Text="成功后等待(ms):" VerticalAlignment="Center" Margin="0,5,5,5"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Node.成功后等待}" Margin="0,5" Width="100"/>
                
                <TextBlock Grid.Row="3" Grid.Column="0" Text="失败后等待(ms):" VerticalAlignment="Center" Margin="0,5,5,5"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Node.失败后等待}" Margin="0,5" Width="100"/>
                
                <TextBlock Grid.Row="4" Grid.Column="0" Text="成功后跳转:" VerticalAlignment="Center" Margin="0,5,5,5"/>
                <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding JumpOptions}" SelectedItem="{Binding SelectedSuccessJump}" Margin="0,5" Width="200"/>
                
                <TextBlock Grid.Row="5" Grid.Column="0" Text="失败后跳转:" VerticalAlignment="Center" Margin="0,5,5,5"/>
                <ComboBox Grid.Row="5" Grid.Column="1" ItemsSource="{Binding JumpOptions}" SelectedItem="{Binding SelectedFailureJump}" Margin="0,5" Width="200"/>
            </Grid>
        </GroupBox>
        
        <GroupBox Grid.Row="1" Header="节点类型" Margin="0,0,0,10">
            <Grid Margin="5">
                <TextBlock Text="{Binding NodeTypeName}" Foreground="#FF666666"/>
            </Grid>
        </GroupBox>
        
        <GroupBox Grid.Row="2" Header="运行条件" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListBox x:Name="ConditionsListBox" Grid.Row="0" MaxHeight="100" MinHeight="24"
                         Background="White" BorderBrush="Gray" BorderThickness="1"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,0">
                    <Button Content="添加条件" Click="AddCondition_Click" Width="75" Margin="0,0,10,0" Padding="5"/>
                    <Button Content="删除选中" Click="RemoveCondition_Click" Width="75" Padding="5"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        
        <GroupBox Grid.Row="3" Header="特有属性">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="CustomPropertiesPanel" Margin="5"/>
            </ScrollViewer>
        </GroupBox>
        
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="确定" Click="OkButton_Click" Width="75" Margin="0,0,10,0" Padding="5"/>
            <Button Content="取消" Click="CancelButton_Click" Width="75" Padding="5"/>
        </StackPanel>
    </Grid>
</Window>