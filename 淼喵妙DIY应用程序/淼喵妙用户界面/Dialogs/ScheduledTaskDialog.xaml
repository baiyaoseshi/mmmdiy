<Window x:Class="淼喵妙用户界面.Dialogs.ScheduledTaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加定时任务" Height="320" Width="420"
        WindowStyle="ToolWindow" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Background="#FF2C2C2C">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" VerticalAlignment="Center">
            <TextBlock Text="任务名称:" Width="80" Foreground="White"/>
            <TextBox Text="{Binding TaskName}" Width="280" Background="#FF3C3C3C" Foreground="White" BorderBrush="#FF5C5C5C"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10" VerticalAlignment="Center">
            <TextBlock Text="脚本文件:" Width="80" Foreground="White"/>
            <TextBox Text="{Binding ScriptPath}" Width="230" Background="#FF3C3C3C" Foreground="White" BorderBrush="#FF5C5C5C" IsReadOnly="True"/>
            <Button Content="浏览" Width="50" Margin="5,0,0,0" Click="BrowseButton_Click" Background="#FF007ACC" Foreground="White"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10" VerticalAlignment="Center">
            <TextBlock Text="调度模式:" Width="80" Foreground="White"/>
            <ComboBox SelectedValue="{Binding 当前调度模式}" SelectedValuePath="Content" Width="280" Background="White" Foreground="Black" TextElement.Foreground="Black">
                <ComboBox.Resources>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="Background" Value="White"/>
                    </Style>
                </ComboBox.Resources>
                <ComboBoxItem>绝对时间</ComboBoxItem>
                <ComboBoxItem>倒计时</ComboBoxItem>
                <ComboBoxItem>重复</ComboBoxItem>
                <ComboBoxItem>循环</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="10,5">
            <StackPanel Visibility="{Binding Is绝对时间, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" Margin="0,3">
                    <TextBlock Text="执行时间:" Width="80" Foreground="White"/>
                    <DatePicker SelectedDate="{Binding ScheduledDateTime}" Width="130" Background="#FF3C3C3C" Foreground="White"/>
                    <TextBox Text="{Binding 执行时间文本, UpdateSourceTrigger=LostFocus}" Width="80" Margin="5,0,0,0" Background="#FF3C3C3C" Foreground="White"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Visibility="{Binding Is倒计时, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" Margin="0,3">
                    <TextBlock Text="延迟时间:" Width="80" Foreground="White"/>
                    <TextBox Text="{Binding 倒计时总秒数}" Width="60" Background="#FF3C3C3C" Foreground="White" BorderBrush="#FF5C5C5C"/>
                    <TextBlock Text="秒" Foreground="White" Margin="5,0,0,0"/>
                    <TextBlock Text="(如 3600=1小时)" Foreground="#FF999999" Margin="10,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Visibility="{Binding Is重复, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" Margin="0,3">
                    <TextBlock Text="重复周期:" Width="80" Foreground="White"/>
                    <ComboBox SelectedValue="{Binding 重复模式}" SelectedValuePath="Content" Width="80" Background="White" Foreground="Black" TextElement.Foreground="Black">
                        <ComboBox.Resources>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Background" Value="White"/>
                            </Style>
                        </ComboBox.Resources>
                        <ComboBoxItem>每天</ComboBoxItem>
                        <ComboBoxItem>每周</ComboBoxItem>
                        <ComboBoxItem>每月</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,3">
                    <TextBlock Text="触发时间:" Width="80" Foreground="White"/>
                    <TextBox Text="{Binding 每日重复时间文本, UpdateSourceTrigger=LostFocus}" Width="80" Background="#FF3C3C3C" Foreground="White" BorderBrush="#FF5C5C5C"/>
                    <TextBlock Text="HH:mm:ss" Foreground="#FF999999" Margin="5,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Visibility="{Binding Is循环, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" Margin="0,3">
                    <TextBlock Text="间隔时间:" Width="80" Foreground="White"/>
                    <TextBox Text="{Binding 循环间隔秒数}" Width="60" Background="#FF3C3C3C" Foreground="White" BorderBrush="#FF5C5C5C"/>
                    <TextBlock Text="秒" Foreground="White" Margin="5,0,0,0"/>
                    <TextBlock Text="(如 1800=30分钟)" Foreground="#FF999999" Margin="10,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="10" VerticalAlignment="Center">
            <CheckBox IsChecked="{Binding IsEnabled}" Content="启用" Foreground="White"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="确定" Width="75" Height="25" Margin="5" Click="OKButton_Click" Background="#FF007ACC" Foreground="White"/>
            <Button Content="取消" Width="75" Height="25" Margin="5" Click="CancelButton_Click" Background="#FF3C3C3C" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
